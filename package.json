{
  "name": "dajho-desktop",
  "type": "module",
  "version": "1.0.0",
  "description": "DAJHO - Gestión completa para tu negocio en laptop",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:direct": "cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json",
    "build": "npm run build:electron && npm run build:renderer",
    "start": "npm run build && npx electron .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.dajho.desktop",
    "productName": "DAJHO",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-pdf": "^5.0.7",
    "@types/xlsx": "^0.0.35",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.3.0",
    "vite": "^7.2.7",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.0",
    "xlsx": "^0.18.5"
  }
}
